# Polymarket Weather Bot - Environment variables
# Copy this to `.env` and fill in only the keys you have.
# The bot runs in DEGRADED MODE if some are missing (uses only the free keyless sources).

# --- Required ---
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# --- Polymarket (LIVE mode only) ---
POLYMARKET_PRIVATE_KEY=
POLYMARKET_PROXY_WALLET=

# --- Weather sources without key (keyless, always on) ---
# Open-Meteo:       no key needed
# NOAA GFS:         no key needed (we send User-Agent)
# ECMWF Open Data:  no key needed
# MET Norway:       no key needed (we send User-Agent)

# --- Weather sources with key (optional, improve ensemble) ---
VISUAL_CROSSING_KEY=YOUR_VISUAL_CROSSING_KEY
OPENWEATHERMAP_KEY=YOUR_OPENWEATHERMAP_KEY
WEATHERAPI_KEY=YOUR_WEATHERAPI_KEY
TOMORROW_IO_KEY=YOUR_TOMORROW_IO_KEY

# --- Telegram alerts (optional) ---
TELEGRAM_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_CHAT_ID

# --- Runtime ---
# Set to `false` for Shadow mode (logs would-be trades without executing).
EXECUTE_TRADES=true
# DEBUG for verbose logs, INFO for normal.
BOT_LOG_LEVEL=INFO
